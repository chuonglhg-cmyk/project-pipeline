# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth - BẮT BUỘC
NEXTAUTH_URL="https://your-app.up.railway.app"
NEXTAUTH_SECRET="your-random-secret-32-chars-min"   # generate: openssl rand -base64 32

# SMTP Email - dùng Gmail
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"   # Gmail App Password (không phải password Gmail thường)
