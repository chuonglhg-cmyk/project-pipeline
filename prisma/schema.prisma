generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id               String    @id @default(cuid())
  companyName      String
  projectName      String
  status           String    @default("New")
  nextStep         String?
  firstContactDate DateTime
  contractSignedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  contacts         Contact[]
  notes            Note[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  position  String?
  isPrimary Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Cấu hình trạng thái dự án - có thể thêm/sửa/xóa qua màn hình Settings
model StatusConfig {
  id           String   @id @default(cuid())
  name         String   @unique  // Tên trạng thái, VD: "New", "Đã demo"
  nextStep     String?           // Bước kế tiếp gợi ý
  color        String   @default("gray")  // Màu badge: gray/blue/yellow/purple/green/red/slate
  order        Int      @default(0)       // Thứ tự hiển thị
  isContractSigned Boolean @default(false) // Đánh dấu trạng thái "đã ký HĐ" để gợi ý nhập ngày
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
